# PostgreSQL primary database configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=albion_factory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=write_your_password_here

# Optional: SQL schema path
SCHEMA_FILE=sql/001_create_core_tables.sql

# Optional: SQLite secondary smoke-test path
SQLITE_PATH=data/test_schema.db

# Model selection
# Default local-first model for non-research roles
MODEL_DEFAULT=ollama/qwen2.5-coder:14b

# Optional role-specific hard overrides
MODEL_REPORT_LEAD=
MODEL_REPORT_VALIDATOR=
MODEL_FACTORY_LEAD_MANAGER=
MODEL_FACTORY_CODER=
MODEL_FACTORY_TESTER=
MODEL_FACTORY_VALIDATOR=
MODEL_OPS_LEAD_MANAGER=
MODEL_OPS_DATA_COLLECTOR=
MODEL_OPS_TESTER=
MODEL_OPS_VALIDATOR=

# Research strategy
# Search and reasoning are split.
# Search chain tries a web-search capable model route if wired, then Serper, then direct fetch, then local knowledge.
SEARCH_MODEL_PRIMARY=
SEARCH_CHAIN=gemini_web_search,serper,direct_fetch,local_knowledge
SEARCH_QUOTA_COOLDOWN_SECONDS=900

# Reasoning chain handles summarization/analysis after sources are found.
MODEL_CHAIN_REPORT_RESEARCHER=gemini/gemini-2.5-flash-lite,gemini/gemini-2.0-flash,ollama/qwen2.5-coder:14b
MODEL_CHAIN_FACTORY_RESEARCHER=gemini/gemini-2.5-flash-lite,gemini/gemini-2.0-flash,ollama/qwen2.5-coder:14b
MODEL_CHAIN_OPS_RESEARCHER=gemini/gemini-2.5-flash-lite,gemini/gemini-2.0-flash,ollama/qwen2.5-coder:14b

# Cooldown after quota/rate-limit detection (seconds)
MODEL_QUOTA_COOLDOWN_SECONDS=900

# Recommended Ollama stability settings for this machine
OLLAMA_CONTEXT_LENGTH=2048
OLLAMA_FLASH_ATTENTION=0
OLLAMA_NUM_PARALLEL=1